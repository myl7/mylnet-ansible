server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ gitea_domain }};

    ssl_certificate {{ gitea_cert }};
    ssl_certificate_key {{ gitea_key }};

    location / {
        proxy_pass http://127.0.0.1:{{ gitea_local_port }};
        include snippets/rproxy.conf;
    }
}
