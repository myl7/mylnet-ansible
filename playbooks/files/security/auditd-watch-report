#!/bin/sh
set -u

state_dir=/var/lib/mylnet-security
checkpoint="$state_dir/auditd-watch.checkpoint"
output=$(mktemp)

cleanup() {
  rm -f "$output"
}
trap cleanup EXIT

mkdir -p "$state_dir"

status=0
ausearch --input-logs --checkpoint "$checkpoint" -k mylnet-hardening -i >"$output" 2>&1 || status=$?

if [ "$status" -eq 1 ]; then
  exit 0
fi

if [ "$status" -eq 10 ] || [ "$status" -eq 11 ] || [ "$status" -eq 12 ]; then
  status=0
  ausearch --input-logs --checkpoint "$checkpoint" --start checkpoint -k mylnet-hardening -i >"$output" 2>&1 || status=$?
  if [ "$status" -eq 1 ]; then
    exit 0
  fi
fi

if [ "$status" -ne 0 ]; then
  echo "auditd watched-file report failed on $(hostname -f 2>/dev/null || hostname)"
  echo
  cat "$output"
  exit 0
fi

if [ -s "$output" ]; then
  echo "auditd watched-file events on $(hostname -f 2>/dev/null || hostname)"
  echo
  cat "$output"
fi
