server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ rsshub_domain }};

    ssl_certificate {{ rsshub_cert }};
    ssl_certificate_key {{ rsshub_key }};

    location / {
        proxy_pass http://127.0.0.1:{{ rsshub_local_port }};
        include snippets/rproxy.conf;
    }
}
