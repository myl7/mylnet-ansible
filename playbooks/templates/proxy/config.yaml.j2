log-level: warning
ipv6: false

listeners:
  - name: ss-in
    type: shadowsocks
    listen: 0.0.0.0
    port: "8388"
    cipher: 2022-blake3-aes-128-gcm
    password: "{{ proxy_ss_password }}"
    udp: true
  - name: mixed-in
    type: mixed
    listen: 0.0.0.0
    port: "10800"

mode: rule
rules:
  - MATCH,DIRECT
