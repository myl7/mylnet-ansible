log-level: error
mixed-port: 7890
allow-lan: false
ipv6: false
mode: rule
unified-delay: true
profile:
  store-selected: true

sniffer:
  enable: true
  parse-pure-ip: true
  force-dns-mapping: true
  override-destination: false
  sniff:
    HTTP:
      ports:
        - 80
        - 443
    TLS:
      ports:
        - 443
  skip-domain:
    # Apple push uses long-lived connections.
    # Sniffing and rewriting will break the push connection.
    - +.push.apple.com
  skip-dst-address:
    # Telegram: Their MTProto uses non-standard TLS without a proper SNI.
    # Sniffing will only yield wrong domains or disrupt the connection.
    - 91.105.192.0/23
    - 91.108.4.0/22
    - 91.108.8.0/21
    - 91.108.16.0/21
    - 91.108.56.0/22
    - 95.161.64.0/20
    - 149.154.160.0/20
    - 185.76.151.0/24
    - 2001:67c:4e8::/48
    - 2001:b28:f23c::/47
    - 2001:b28:f23f::/48
    - 2a0a:f280:203::/48

dns:
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - "*"
    - +.lan
    - +.local
    - time.*.com
    - ntp.*.com
    - +.market.xiaomi.com
    - "*.ts.net"
  fake-ip-filter-mode: blacklist
  use-hosts: false
  use-system-hosts: true
  respect-rules: true
  default-nameserver:
    - tls://223.5.5.5
    - tls://1.1.1.1
  nameserver:
    - https://doh.pub/dns-query
    - https://dns.alidns.com/dns-query
    - https://1.1.1.1/dns-query
  proxy-server-nameserver:
    - https://doh.pub/dns-query
    - https://dns.alidns.com/dns-query
    - https://1.1.1.1/dns-query
  direct-nameserver: []
  fallback: []
  fallback-filter:
    geoip: true
    geoip-code: CN
    ipcidr:
      - 240.0.0.0/4
      - 0.0.0.0/32
    domain:
      - +.google.com
      - +.facebook.com
      - +.youtube.com

geodata-mode: false
geo-auto-update: true
geo-update-interval: 24
geox-url:
  geoip: "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geoip-lite.dat"
  geosite: "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geosite.dat"
  mmdb: "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geoip.metadb"
  asn: "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/GeoLite2-ASN.mmdb"

proxies:
{% for proxy_host in proxy_hostnames %}
  - name: {{ proxy_host | to_json }}
    type: ss
    server: {{ proxy_hosts[proxy_host] | to_json }}
    port: 8388
    cipher: 2022-blake3-aes-128-gcm
    password: {{ proxy_ss_passwords[proxy_host] | to_json }}
    udp: true
{% endfor %}

proxy-groups:
  - name: default
    type: select
    proxies:
      - DIRECT
      - proxy
  - name: proxy
    type: select
    proxies:
{% for proxy_host in proxy_hostnames | move_first(proxy_proxy_hostname) %}
      - {{ proxy_host | to_json }}
{% endfor %}
      - DIRECT
  - name: cn
    type: select
    proxies:
      - DIRECT
{% for proxy_host in proxy_hostnames %}
      - {{ proxy_host | to_json }}
{% endfor %}
  - name: ai
    type: select
    proxies:
{# AI requires stable IPs, so we do not use the proxy group #}
{% for proxy_host in proxy_hostnames | move_first(proxy_ai_hostname) %}
      - {{ proxy_host | to_json }}
{% endfor %}
      - DIRECT

{% set openai_asns = [401518, 401864] %}{# OpenAI #}
{% set anthropic_asns = [399358] %}{# Anthropic #}
{% set proxy_ai_asns = proxy_ai_asns | default(openai_asns + anthropic_asns) %}

rule-providers:
  anti-ad:
    type: http
    behavior: domain
    format: yaml
    url: "https://anti-ad.net/clash.yaml"
    path: ./ruleset/anti-ad.yaml
    interval: 86400

rules:
  - GEOSITE,private,DIRECT
  - GEOIP,private,DIRECT,no-resolve
  - DOMAIN-SUFFIX,ts.net,DIRECT

  - RULE-SET,anti-ad,REJECT

  - DOMAIN,downloads.claude.ai,default
  - DOMAIN-KEYWORD,claude,ai
  - DOMAIN-KEYWORD,anthropic,ai
  - DOMAIN-KEYWORD,chatgpt,ai
  - DOMAIN-KEYWORD,openai,ai
  - DOMAIN-KEYWORD,gemini,ai
  - DOMAIN-SUFFIX,aistudio.google.com,ai
  - DOMAIN-SUFFIX,generativelanguage.googleapis.com,ai
  - DOMAIN-KEYWORD,openrouter,ai
  - DOMAIN-KEYWORD,groq,ai

{{ lookup('ansible.builtin.file', 'secrets/clash_rules_extend.yaml').split('\n')[1:] | join('\n') }}

  - GEOSITE,cn,cn

{% for proxy_ai_asn in proxy_ai_asns %}
  - IP-ASN,{{ proxy_ai_asn }},ai
{% endfor %}

  - GEOIP,CN,cn
  - MATCH,default
