server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ uptime_domain }};

    ssl_certificate {{ uptime_cert }};
    ssl_certificate_key {{ uptime_key }};

    location / {
        proxy_pass http://127.0.0.1:{{ uptime_local_port }};
        include snippets/rproxy.conf;
    }
}
