server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ vaultwarden_domain }};

    ssl_certificate {{ vaultwarden_cert }};
    ssl_certificate_key {{ vaultwarden_key }};

    location / {
        proxy_pass http://127.0.0.1:{{ vaultwarden_local_port }};
        include snippets/rproxy.conf;
    }
}
