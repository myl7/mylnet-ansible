server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name {{ gost_domain }};

    ssl_certificate     {{ gost_cert }};
    ssl_certificate_key {{ gost_key }};

    location = /{{ gost_path }} {
        proxy_pass http://127.0.0.1:{{ gost_local_port }};
        include snippets/rproxy.conf;
        proxy_read_timeout 1h;
        proxy_send_timeout 1h;
        proxy_buffering off;
    }

    location / {
        return 404;
    }
}
