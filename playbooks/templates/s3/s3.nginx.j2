server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ s3_domain }};

    ssl_certificate {{ s3_cert }};
    ssl_certificate_key {{ s3_key }};

    location / {
        proxy_pass http://127.0.0.1:{{ rustfs_api_local_port }};
        include snippets/rproxy.conf;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ s3_console_domain }};

    ssl_certificate {{ s3_console_cert }};
    ssl_certificate_key {{ s3_console_key }};

    location / {
        proxy_pass http://127.0.0.1:{{ rustfs_console_local_port }};
        include snippets/rproxy.conf;
    }
}
