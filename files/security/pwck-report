#!/bin/sh
set -u

raw_output=$(mktemp)
filtered_output=$(mktemp)
uid0_output=$(mktemp)

cleanup() {
  rm -f "$raw_output" "$filtered_output" "$uid0_output"
}
trap cleanup EXIT

status=0
pwck -r >"$raw_output" 2>&1 || status=$?

grep -Ev "^user '[^']+': directory '[^']+' does not exist$|^pwck: no changes$" "$raw_output" >"$filtered_output" || true
getent passwd | awk -F: '$3 == 0 && $1 != "root" { print }' >"$uid0_output"

if [ -s "$filtered_output" ] || [ -s "$uid0_output" ]; then
  echo "passwd/shadow health check warning on $(hostname -f 2>/dev/null || hostname)"
  echo
  echo "pwck exit status: $status"
  echo

  if [ -s "$filtered_output" ]; then
    echo "Unexpected pwck output:"
    cat "$filtered_output"
    echo
  fi

  if [ -s "$uid0_output" ]; then
    echo "Unexpected UID 0 accounts:"
    cat "$uid0_output"
  fi
fi
